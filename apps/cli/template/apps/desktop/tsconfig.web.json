{
  "extends": "@repo/typescript-config/electron-renderer.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@repo/*": ["./../../packages/*"]
    }
  }
}
