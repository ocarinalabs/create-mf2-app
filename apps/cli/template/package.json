{
  "name": "mf2-app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "turbo test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "bunx npm-check-updates --deep -u -p bun && bun install",
    "bump-ui": "bunx shadcn@latest add --all --overwrite -c packages/design-system",
    "bump-ui-native": "bunx --bun @react-native-reusables/cli@latest add --all --overwrite -c apps/mobile",
    "clean": "git clean -xdf node_modules",
    "convex-lint": "turbo convex-lint",
    "env:init": "bun scripts/env.ts init",
    "env:check": "bun scripts/env.ts check",
    "env:push": "bun scripts/env.ts push",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.9.6",
    "@types/node": "^25.6.0",
    "lefthook": "^2.1.5",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "ultracite": "7.4.4",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.12",
  "overrides": {
    "parse5": "^7.2.1"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css}": "ultracite fix"
  }
}
