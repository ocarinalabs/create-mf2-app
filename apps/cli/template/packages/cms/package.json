{
  "name": "@repo/cms",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "[ -z \"$BASEHUB_TOKEN\" ] && echo 'Skipping CMS: set BASEHUB_TOKEN to enable' || basehub dev",
    "build": "[ -z \"$BASEHUB_TOKEN\" ] && echo 'Skipping CMS build: set BASEHUB_TOKEN to enable' || basehub build",
    "analyze": "basehub",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "^0.13.11",
    "basehub": "^9.5.3",
    "react": "19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next": "16.2.3"
  }
}
